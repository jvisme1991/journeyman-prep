# Copy this file to .env.local (which is already gitignored) and fill in
# your actual Supabase project values. Both variables must be prefixed with
# NEXT_PUBLIC_ since this is a client-only integration (no server routes) --
# the anon key is designed to be public and is safe to expose in the browser
# bundle as long as Row Level Security policies are enabled on every table.

# Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Project Settings -> API -> Project API keys -> anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
